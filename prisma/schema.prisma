generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TypeProperty {
  APARTMENT
  HOUSE
  TOWNHOUSE
  STUDIO
}

enum VisitStatus {
  PENDING
  SCHEDULED
  REALIZED
  NO_SHOW
  CANCELED
}

enum UserRole {
  ADMIN
  OWNER
  VISITOR
}

model Property {
  id String @id @default(uuid())

  ownerId          String
  name             String
  description      String       @db.Text
  type             TypeProperty @default(APARTMENT)
  latitude         Decimal      @db.Decimal(12, 8)
  longitude        Decimal      @db.Decimal(12, 8)
  address          String
  total_value      Decimal      @db.Decimal(10, 2)
  size             Decimal      @db.Decimal(10, 2)
  number_of_rooms  Int
  number_of_baths  Int
  parking_spaces   Int
  tax_value        Decimal      @db.Decimal(10, 2)
  condo_value      Decimal      @db.Decimal(10, 2)
  are_pets_allowed Boolean      @default(true)
  is_next_subway   Boolean      @default(false)
  is_furnished     Boolean      @default(false)
  is_active        Boolean      @default(true)
  is_sale          Boolean      @default(false)
  is_rent          Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner User @relation("property-owner", fields: [ownerId], references: [id])

  visits Visits[] @relation("visit-record")
}

model Visits {
  id String @id @default(uuid())

  propertyId   String
  visitorName  String
  visitorPhone String
  visitorEmail String
  visitDate    DateTime
  visitStatus  VisitStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property @relation("visit-record", fields: [propertyId], references: [id])
}

model User {
  id    String   @id @default(uuid())
  name  String
  email String @unique
  phone String
  role  UserRole @default(OWNER)
  password String

  properties Property[] @relation("property-owner")
}
